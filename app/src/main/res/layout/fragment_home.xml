<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_status_ok"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🟢 Radar ativo"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="8dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_enable_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ativar Acessibilidade"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_restricted_settings_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Se o botão acima não conseguir ativar a Acessibilidade: vá em Ajustes → Apps → Radar → toque no menu (⋮) no canto superior direito → &quot;Permitir configurações restritas&quot;. Depois volte e ative a Acessibilidade de novo. Isso acontece toda vez que um APK novo é instalado por fora da Play Store."
            android:textSize="12sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_enable_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Permitir overlay"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_disable_battery_optimization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Permitir rodar em segundo plano (bateria)"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DIAGNÓSTICO DA CAPTURA" android:textSize="12sp" android:layout_marginBottom="8dp"/>

                <TextView android:id="@+id/tv_installed_at" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Build instalado em: —"
                    android:textSize="12sp" android:layout_marginBottom="4dp" />

                <TextView android:id="@+id/tv_accessibility_state" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Serviço de acessibilidade: verificando" />

                <TextView android:id="@+id/tv_service_connected_at" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Serviço conectado em: nunca" />

                <TextView android:id="@+id/tv_last_package" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Último pacote: nenhum" />

                <TextView android:id="@+id/tv_last_event" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Último evento: nenhum" />

                <TextView android:id="@+id/tv_last_read_time" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Última leitura com texto: nunca" />

                <TextView android:id="@+id/tv_captured_count" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="Textos capturados: 0" />

                <TextView android:id="@+id/tv_last_captured_texts" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="8dp"
                    android:text="Nenhum texto capturado ainda." android:textIsSelectable="true"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_accessibility_debug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Atualizar diagnóstico" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_full_log"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Ver log completo (radar_debug.txt)" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOJE"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Bruto" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_gross_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="R$ 0,00"
                        android:textSize="20sp" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lucro real" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_net_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="R$ 0,00"
                        android:textSize="20sp" android:textStyle="bold" android:textColor="#4CAF50" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Corridas" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_trip_count" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 corridas"
                        android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Média/hora" android:textSize="12sp" />
                    <TextView android:id="@+id/tv_avg_per_hour" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="R$ 0,00/h"
                        android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Corridas por nota" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tv_grade_stats" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="✅ 0  ⚠️ 0  ❌ 0"
                    android:textSize="20sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
